---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const { title = "BJTN // Mega Man Portfolio", description = "Brandon Jose Tenorio Noguera - Software Engineer, musician, and Mega Man fan" } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Theme selection: restore saved choice or randomize. Runs before paint. -->
    <script is:inline>
      (function() {
        var themes = [
          "megaman","protoman","bass","zero","roll",
          "pokemon-red","pokemon-blue","pokemon-gold","pokemon-emerald",
          "overwatch","dva","genji","reaper"
        ];
        var saved = null;
        try { saved = localStorage.getItem("bjtn-theme"); } catch(e) {}
        var theme = (saved && themes.indexOf(saved) !== -1) ? saved : themes[Math.floor(Math.random() * themes.length)];
        document.documentElement.setAttribute("data-theme", theme);
        var franchise = theme.indexOf("pokemon") === 0 ? "pokemon"
          : (theme === "overwatch" || theme === "dva" || theme === "genji" || theme === "reaper") ? "overwatch"
          : "megaman";
        document.documentElement.setAttribute("data-franchise", franchise);
      })();
    </script>
  </head>
  <body
    class="min-h-screen font-[JetBrains_Mono,monospace] antialiased scanlines mm-grid-bg"
    style="background-color: var(--t-bg);"
  >
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<style>
html,
body {
  margin: 0;
  padding: 0;
  width: 100%;
  height: 100%;
  scroll-behavior: smooth;
}
</style>
